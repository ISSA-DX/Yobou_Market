<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!--
      Yobou brand background for adaptive launcher icons.
      Vertical gradient: lighter Yobou blue at top -> deeper primary blue at
      bottom. Gives the white Y+bag mark visual lift without competing with it.
    -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#0047f1"
                android:endColor="#0034b9"
                android:type="linear" />
        </shape>
    </item>

    <!-- Subtle inner highlight at the top for a "glass tile" feel -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#33FFFFFF"
                android:endColor="#00FFFFFF"
                android:type="linear" />
        </shape>
    </item>
</layer-list>