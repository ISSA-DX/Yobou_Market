<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
      Yobou Market logo (adaptive-icon foreground).
      Concept: rounded-rectangle shopping-bag silhouette in white with a Y
      monogram "cut out" in the brand blue, plus a small gold price-tag
      chip at the upper-right of the bag. The bag is what makes "market"
      legible at 48dp; the Y stays for brand recognition; the tag replaces
      the old decorative dot with a commerce-meaningful shape.

      All geometry sits inside the 66dp safe zone (centered on the
      108x108 viewport). Coordinate notes:
        bag body ......... x=22..86, y=36..90 (chamfered corners r=8)
        bag handle ....... y=22..40, x=40..68 (trapezoid)
        Y apex junction .. (54, 64)
        Y arm tops ....... y=50, x=36..72 (8-unit thickness)
        Y stem drops ..... (54, 64) → (54, 80)
        price tag ........ center (80, 32), body 11×8, tip dx=4 dy=4
    -->

    <!--
      Bag handle — drawn first so the bag body overlaps it cleanly along
      the bag's top edge.
    -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M44,22 L64,22 L68,40 L40,40 Z" />

    <!--
      Bag body — chamfered rectangle. The corners are smoothed by an extra
      group of four small circles below, since vector pathData can't do
      "rounded-rectangle" with corner radius directly without arc commands.
    -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M30,36 L78,36 L86,44 L86,82 L78,90 L30,90 L22,82 L22,44 Z" />

    <!--
      Corner-rounding circles — overlay the chamfered corners so the bag
      reads as a proper rounded rectangle at full resolution.
    -->
    <path android:fillColor="#FFFFFF" android:pathData="M30,36 m-8,0 a8,8 0,1 1,16 0 a8,8 0,1 1,-16 0" />
    <path android:fillColor="#FFFFFF" android:pathData="M78,36 m-8,0 a8,8 0,1 1,16 0 a8,8 0,1 1,-16 0" />
    <path android:fillColor="#FFFFFF" android:pathData="M30,90 m-8,0 a8,8 0,1 1,16 0 a8,8 0,1 1,-16 0" />
    <path android:fillColor="#FFFFFF" android:pathData="M78,90 m-8,0 a8,8 0,1 1,16 0 a8,8 0,1 1,-16 0" />

    <!--
      Y monogram in brand blue (#0047f1) — drawn ON TOP of the white bag
      so it reads as negative space inside the bag silhouette.
    -->
    <path
        android:fillColor="#0047f1"
        android:pathData="M36,50 L44,50 L58,64 L50,64 Z" />
    <path
        android:fillColor="#0047f1"
        android:pathData="M72,50 L64,50 L50,64 L58,64 Z" />
    <path
        android:fillColor="#0047f1"
        android:pathData="M50,64 L58,64 L59,80 L49,80 Z" />

    <!--
      Gold price tag — rounded rectangle with a small triangular tip
      extending down-right, plus a transparent circle for the string
      hole. Sits at the upper-right of the bag.
    -->
    <path
        android:fillColor="#fdc003"
        android:pathData="M74.5,28 L85.5,28 L89.5,32 L85.5,36 L74.5,36 Z" />
    <path
        android:fillColor="#0047f1"
        android:pathData="M77.5,32 m-1.2,0 a1.2,1.2 0,1 1,2.4 0 a1.2,1.2 0,1 1,-2.4 0" />
</vector>