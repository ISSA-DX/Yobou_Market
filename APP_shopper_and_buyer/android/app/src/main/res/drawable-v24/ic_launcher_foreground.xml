<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
      Yobou Market logo (adaptive-icon foreground)
      Design: stylized "Y" whose two upper arms form the handles of a shopping bag.
      The bag body sits below, completing the marketplace read.
      Palette: white Y on Yobou primary blue background; gold (#fdc003) accent
      for the bag highlight. Sized to fit within the 66dp safe zone of an
      Android adaptive icon (centered around 54,54 with 24dp padding from the
      108x108 viewport).
    -->

    <!-- Soft glow ring behind the mark so it lifts off the blue background -->
    <path
        android:fillType="evenOdd"
        android:pathData="M54,54m-30,0a30,30 0,1 1,60 0a30,30 0,1 1,-60 0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="30"
                android:type="radial">
                <item android:color="#33FFFFFF" android:offset="0.0" />
                <item android:color="#00FFFFFF" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!--
      Shopping bag body (white) with subtle inner highlight on top.
      Bag spans roughly x:[34..74], y:[58..82] inside the 108x108 viewport.
    -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M34,60 L74,60 L71,84 L37,84 Z" />

    <!--
      Bag handles — these are the two upper arms of the "Y", curving up and
      meeting at a point above the bag, forming the Y letterform.
      Left handle: starts at bag top-left (~44,60), arcs up and right to apex (~54,46).
      Right handle: starts at bag top-right (~64,60), arcs up and left to apex (~54,46).
    -->
    <path
        android:fillColor="#FFFFFF"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="5"
        android:strokeLineCap="round"
        android:pathData="M44,60 C44,52 48,46 54,46 C60,46 64,52 64,60 L60,60 C60,54 57,50 54,50 C51,50 48,54 48,60 Z" />

    <!--
      Y stem: short vertical from the apex down through the bag top to about
      mid-bag. Reads as the descender of the Y inside the bag.
    -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M51,46 L57,46 L57,70 L51,70 Z" />

    <!--
      Gold accent: a small horizontal highlight bar across the top of the bag,
      echoing the in-app #fdc003 accent color. Sits just under the handles.
    -->
    <path
        android:fillColor="#fdc003"
        android:pathData="M37,68 L71,68 L70.5,72 L37.5,72 Z" />

    <!--
      Tiny gold dot accent inside the bag bottom — the "Yobou mark" inside the
      marketplace bag. Adds visual interest without clutter.
    -->
    <path
        android:fillColor="#fdc003"
        android:pathData="M54,76 m-2,0 a2,2 0,1 1,4 0 a2,2 0,1 1,-4 0" />
</vector>