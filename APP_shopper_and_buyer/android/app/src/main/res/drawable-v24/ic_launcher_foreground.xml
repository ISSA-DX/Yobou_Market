<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
      Yobou Market logo (adaptive-icon foreground).
      Concept: Bold Y monogram with a flared bag-footprint base.
      The Y is one solid white silhouette that survives at 48dp; the
      flared base implies a shopping-bag opening without drawing one.
      A single gold (#fdc003) dot in the upper-right is the only warm
      accent and prevents the icon from feeling cold.

      All geometry sits inside the 66dp safe zone (centered on the
      108x108 viewport). Coordinate notes:
        apex junction ........ (54, 38)
        arm tops ............. y=14, x=18..90 (with 11-unit thickness)
        stem drops ........... (54, 38) → (54, 70)
        flared base .......... x=43..65, y=70..90
        gold accent dot ...... (84, 30), 4-unit radius
    -->

    <!-- Soft glow ring behind the Y — lifts it off the blue gradient -->
    <path
        android:fillType="evenOdd"
        android:pathData="M54,52m-38,0a38,38 0,1 1,76 0a38,38 0,1 1,-76 0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="54"
                android:centerY="52"
                android:gradientRadius="38"
                android:type="radial">
                <item android:color="#28FFFFFF" android:offset="0.0" />
                <item android:color="#00FFFFFF" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!--
      Left arm of the Y — a parallelogram from the apex junction up-and-left
      to the upper-left of the canvas. 11-unit thickness, even weight.
    -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M18,14 L29,14 L57,38 L46,38 Z" />

    <!--
      Right arm of the Y — mirror of the left, going up-and-right.
    -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M90,14 L79,14 L51,38 L62,38 Z" />

    <!--
      Stem + flared base — one continuous shape. The stem drops from the
      apex junction to y=70; below that the form flares out to 22 units
      wide, reading as the top opening of a shopping bag without drawing
      any additional illustration. This is the silhouette cue.
    -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M47,38 L61,38 L65,70 L65,90 L43,90 L43,70 Z" />

    <!--
      Gold accent dot — single 4-unit-radius circle tucked into the
      upper-right negative space, under the right arm. At small sizes it
      reads as a warm pixel; at full size it's a deliberate highlight.
    -->
    <path
        android:fillColor="#fdc003"
        android:pathData="M84,26 m-4,0 a4,4 0,1 1,8 0 a4,4 0,1 1,-8 0" />
</vector>
