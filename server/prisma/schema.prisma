generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// NOTE: SQLite has no native ENUM, so we use String fields with
// documented value sets. The server validates values via zod (see
// server/src/lib/validators.js). Postgres would let us upgrade
// these to real enums by switching the datasource provider.
model User {
  id                     String          @id @default(cuid())
  email                  String          @unique
  passwordHash           String
  name                   String
  role                   String // 'ADMIN' | 'VENDOR' | 'CUSTOMER'
  vendor                 Vendor?
  addresses              Address[]
  paymentMethods         PaymentMethod[]
  orders                 Order[]
  cartItems              CartItem[]
  refundsRequested       Refund[]        @relation("RefundRequester")
  refundsReviewed        Refund[]        @relation("RefundReviewer")
  productChangesReviewed ProductChange[] @relation("ProductChangeReviewer")
  auditLogEntries        AdminAuditLog[]
  notifications          Notification[]
  reviews                Review[]

  // Preferences
  language           String  @default("en")
  currency           String  @default("USD")
  theme              String  @default("system") // light | dark | system
  notifyOrderUpdates Boolean @default(true)
  notifyPromotions   Boolean @default(false)
  notifyShipping     Boolean @default(true)
  marketingConsent   Boolean @default(false)

  // Soft disable: when set, auth middleware blocks login/refresh.
  disabledAt DateTime?

  // Last activity timestamp used by the SSE connection housekeeper.
  lastSeenAt DateTime?

  createdAt DateTime @default(now())
}

model Vendor {
  id           String          @id @default(cuid())
  userId       String          @unique
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessName String
  phone        String
  licenseUrl   String?
  categories   String          @default("[]") // JSON array of selected categories
  // Public-facing brand assets — URL strings because uploads are served
  // by the same /uploads/* route as product images.
  logoUrl      String?
  bannerUrl    String?
  status       String          @default("PENDING") // PENDING | APPROVED | REJECTED
  approvedAt   DateTime?
  products     Product[]
  changes      ProductChange[]
  createdAt    DateTime        @default(now())
}

model Product {
  id          String           @id @default(cuid())
  vendorId    String?
  vendor      Vendor?          @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  name        String
  description String
  priceCents  Int
  // Optional list/deal price. When set and strictly greater than
  // priceCents, the storefront renders a strikethrough and a "X% off"
  // badge. Null = no deal. Validation that compareAt > price lives in
  // the zod validator (see server/src/lib/validators.js); keeping the
  // invariant at the validator layer means the form can accept a
  // "remove the deal" empty value without the DB caring.
  compareAtPriceCents Int?
  category    String
  imageUrls   String           @default("[]") // JSON array
  // `stock` is the canonical available-quantity count for the storefront:
  // when the product has variants, it's the SUM(variants.stock); when no
  // variants exist, it's the legacy single number the admin entered.
  // Server routes keep this in sync inside the same transaction as any
  // variant write (see server/src/routes/products.js applyVariants).
  stock       Int              @default(0)
  status      String           @default("LIVE") // LIVE / DRAFT / HIDDEN
  // Placement flags. Each controls whether the product appears on a
  // given shopper surface. Defaults: home/deals/search ON, flash OFF
  // (Flash is meant to be a curated subset, not a free-for-all).
  //   - showOnHome: Home main grid (and anywhere the unfiltered
  //     /api/products list is rendered, except Deals/Flash which have
  //     their own flags).
  //   - showOnDeals: Home Deals rail. Auto-detection
  //     (compareAt > price) is still applied on top of this flag, so
  //     a product with showOnDeals=false is never in the rail even
  //     if it has a strikethrough price.
  //   - showOnFlashDeals: Home Flash deals rail. New curated surface.
  //   - showOnSearch: surfaces that match buyer search queries
  //     (APP_shopper_and_buyer /api/products?q= and the partner app).
  showOnHome        Boolean         @default(true)
  showOnDeals       Boolean         @default(true)
  showOnFlashDeals  Boolean         @default(false)
  showOnSearch      Boolean         @default(true)
  createdAt   DateTime         @default(now())
  orderItems  OrderItem[]
  cartItems   CartItem[]
  changes     ProductChange[]
  variants    ProductVariant[]
  reviews     Review[]
  // Additional category pin targets (in addition to the primary
  // `category` string). Free-text names, matching the convention of
  // the primary `category` column — the curated `Category` table is a
  // subset, not the source of truth. This round stores them but does
  // not yet expose them via the public /api/products?category=
  // filter; see plan "Deferred work".
  extraCategories CategoryExtra[]
}

// Color/size variants with per-option stock. A product with at least one
// variant shows a Color+Size picker on the storefront; without variants
// the product uses the legacy single-stock UX. See
// server/src/lib/validators.js `productUpsert.variants` for the wire shape.
model ProductVariant {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  color     String // free-text: "Black", "Dark Red", or anything the admin typed
  size      String // free-text: "S", "XL", "42", "One Size"
  stock     Int      @default(0)
  // Per-color photo gallery override. Empty array = fall back to the
  // product-level imageUrls on the storefront. Each row is an absolute
  // URL the same shape as Product.imageUrls. Capped at 10 by the
  // zod validator (see server/src/lib/validators.js variantInput).
  imageUrls String   @default("[]") // JSON array
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  // Back-relation so cart-items can resolve to the source variant
  // row for inventory accounting.
  cartItems CartItem[]

  @@unique([productId, color, size]) // prevent duplicate variant rows for the same combo
  @@index([productId])
}

// Curated catalogue of product categories. Replaces the free-form
// `Product.category` string as the source of truth at write time; the
// existing string column is preserved for historical rows and so the
// shopper app's CategoryDetail page (`?category=<slug>`) keeps working
// without a migration. `isActive=false` is a soft-delete that hides the
// category from the picker while keeping existing products addressable.
model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

// Many-to-many opt-in: a product's additional category pin targets
// (in addition to the primary `Product.category` string). One row per
// (product, name); deduped via @@unique. Cascade-deleted with the
// product so admin delete stays clean. This is metadata-only this
// round — the public /api/products?category= filter still uses the
// primary `category` string, not this table. The plan calls out a
// 30-line follow-up to wire the OR clause when the user wants it.
model CategoryExtra {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime @default(now())

  @@unique([productId, name]) // same product can't be pinned twice to the same name
  @@index([name]) // future multi-cat filter would look up by name
}

model CartItem {
  id        String  @id @default(cuid())
  userId    String
  productId String
  // VariantId is set when the shopper picked a specific color/size
  // row of a variant-enabled product. Null on legacy single-stock
  // products. Per-variant inventory accounting lives here so the
  // cart's stock check is accurate.
  variantId String?
  quantity  Int     @default(1)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  // A user can only have one cart row per (product, variant) combo;
  // for legacy products variantId is null and the unique still works
  // because SQLite treats NULL as distinct.
  @@unique([userId, productId, variantId])
}

model Address {
  id            String  @id @default(cuid())
  userId        String
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipientName String?
  line1         String
  city          String
  state         String
  postal        String
  isDefault     Boolean @default(false)
  orders        Order[]

  @@index([userId])
}

model PaymentMethod {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String // 'CARD'
  brand       String // 'visa' | 'mastercard' | 'amex' | 'discover'
  last4       String
  expiryMonth String
  expiryYear  String
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId])
}

model Order {
  id             String  @id @default(cuid())
  userId         String
  user           User    @relation(fields: [userId], references: [id])
  status         String  @default("PLACED") // PLACED | PAID | PROCESSING | SHIPPED | DELIVERED | CANCELLED | REFUNDED
  subtotalCents  Int     @default(0)
  shippingCents  Int     @default(0)
  totalCents     Int
  paymentMethod  String // CARD | PAYPAL | COD
  paymentTxnId   String?
  addressId      String
  address        Address @relation(fields: [addressId], references: [id], onDelete: Restrict)
  snapshotName   String?
  snapshotLine1  String?
  snapshotCity   String?
  snapshotState  String?
  snapshotPostal String?

  // Delivery tracking — populated when status transitions to SHIPPED.
  trackingNumber    String?
  carrier           String? // 'DHL' | 'FedEx' | 'UPS' | 'USPS' | 'YobouDirect' | 'Other'
  shippedAt         DateTime?
  estimatedDelivery DateTime?

  // Cancellation record — populated when admin cancels.
  cancelReason String?
  cancelledBy  String? // userId of the admin who initiated

  items     OrderItem[]
  timeline  TimelineEvent[]
  refunds   Refund[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String
  productId  String
  quantity   Int
  priceCents Int
  order      Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product    Product @relation(fields: [productId], references: [id])
}

model TimelineEvent {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    String
  at        DateTime @default(now())
  // Actor attribution — who or what caused this transition. Optional
  // because pre-existing rows and system-driven events (payment
  // confirmation, refund approval) may not have a user attached.
  actorId   String?
  actorRole String? // 'ADMIN' | 'VENDOR' | 'SYSTEM'
  note      String?
}

model ProductChange {
  id                  String    @id @default(cuid())
  vendorId            String
  vendor              Vendor    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  productId           String? // null for CREATE
  product             Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  action              String // CREATE | UPDATE | DELETE
  // Proposed snapshot for CREATE/UPDATE; null fields ignored on UPDATE
  proposedName        String?
  proposedDescription String?
  proposedPriceCents  Int?
  // Proposed list/deal price. Mirrors Product.compareAtPriceCents —
  // a non-null value is applied on admin approval; null is a no-op
  // (preserves the existing value). To REMOVE an existing deal the
  // vendor would need a separate "clear compareAt" affordance; for
  // now this is intentionally write-only.
  proposedCompareAtPriceCents Int?
  proposedCategory    String?
  proposedImageUrls   String? // JSON array
  proposedStock       Int?
  proposedStatus      String?
  // JSON snapshot of proposed variants [{color, size, stock}] — vendor
  // proposals go through this column and the admin-approval path applies
  // them in a transaction alongside Product.stock. `variantsAction`
  // distinguishes "replace all variants" (the default for any UPDATE
  // that sets the field) from a no-op leave-existing.
  proposedVariants    String?
  variantsAction      String? // 'replace' | null — currently always 'replace' when set
  // Proposed placement flags. Mirror Product.showOn* and apply on
  // admin approval. Null fields on UPDATE mean "leave the existing
  // Product value alone" (the standard proposed* convention in this
  // model); on CREATE, null fields fall through to the schema
  // defaults (home=true, deals=true, flash=false, search=true) so
  // vendors don't have to opt in just to publish a new product.
  proposedShowOnHome       Boolean?
  proposedShowOnDeals      Boolean?
  proposedShowOnFlashDeals Boolean?
  proposedShowOnSearch     Boolean?
  // JSON-encoded string[] of extra category names. Mirrors the
  // existing proposedImageUrls / proposedVariants pattern. On
  // approval the route handler deletes-and-recreates the
  // CategoryExtra rows for the affected product.
  proposedExtraCategories  String?
  // Review
  status              String    @default("PENDING") // PENDING | APPROVED | REJECTED
  reviewedById        String?
  reviewedAt          DateTime?
  adminNote           String?
  createdAt           DateTime  @default(now())
  reviewedBy          User?     @relation("ProductChangeReviewer", fields: [reviewedById], references: [id])

  @@index([vendorId, status])
}

model Refund {
  id            String    @id @default(cuid())
  orderId       String
  order         Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  requestedById String
  requestedBy   User      @relation("RefundRequester", fields: [requestedById], references: [id])
  reason        String
  amountCents   Int
  status        String    @default("PENDING") // PENDING | APPROVED | REJECTED | PROCESSED
  reviewedById  String?
  reviewedAt    DateTime?
  adminNote     String?
  refundTxnId   String?
  createdAt     DateTime  @default(now())
  reviewedBy    User?     @relation("RefundReviewer", fields: [reviewedById], references: [id])

  @@index([orderId])
  @@index([status])
}

// In-app notification — written by the notification helper and surfaced
// via the inbox endpoint and SSE push. We don't send email/SMS/push in
// this iteration; the inbox is the only delivery channel.
model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      String // 'order_status' | 'order_placed' | 'order_cancelled'
  // | 'product_approved' | 'product_rejected'
  // | 'vendor_approved' | 'vendor_rejected'
  // | 'tracking_updated' | 'admin_broadcast'
  title     String
  body      String
  link      String? // app-internal path like "/orders/abc/track" or "/products/xyz"
  meta      String? // JSON of kind-specific payload (orderId, status, etc.)
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

// Diagnostic record for live SSE connections. The authoritative state
// is the in-memory `sseClients` map (see server/src/lib/notifications.js)
// because broadcast must not wait on a DB write; this table exists for
// observability and post-mortem analysis only.
model SseConnection {
  id        String   @id @default(cuid())
  userId    String
  role      String // 'ADMIN' | 'VENDOR' | 'CUSTOMER'
  lastSeen  DateTime @updatedAt
  createdAt DateTime @default(now())

  @@index([userId])
}

// Admin action audit trail. Every write that goes through admin-gated
// routes appends an entry. Read-only for admins via /api/admin/audit-log.
model AdminAuditLog {
  id         String   @id @default(cuid())
  actorId    String
  actor      User     @relation(fields: [actorId], references: [id])
  action     String // 'order.cancel' | 'order.ship' | 'order.status'
  // | 'product.create' | 'product.update' | 'product.delete'
  // | 'vendor.approve' | 'vendor.reject' | 'vendor.suspend'
  // | 'refund.approve' | 'refund.reject'
  // | 'broadcast.send'
  // | 'user.role' | 'user.disable'
  entityType String // 'order' | 'product' | 'vendor' | 'refund' | 'user' | 'broadcast'
  entityId   String?
  meta       String? // JSON of relevant fields (reason, tracking, etc.)
  createdAt  DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([entityType, entityId])
}

// Customer-submitted product review. One review per (user, product) —
// the @@unique below enforces that at the DB layer; the route handler
// also maps a P2002 violation to 409 REVIEW_EXISTS so the UI gets a
// clean error instead of a stack trace.
//
// "Verified purchase" is computed at read time in the reviews route
// (a `verifiedPurchase` boolean is attached per row when an OrderItem
// for this product exists on a PAID/PROCESSING/SHIPPED/DELIVERED
// order belonging to the reviewer). We do NOT cache it on the row —
// an order moving to SHIPPED after the review was written would
// otherwise need a back-fill.
model Review {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Int // 1..5
  title     String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId]) // one review per shopper per product
  @@index([productId, createdAt]) // list-by-recent path
  @@index([productId, rating]) // histogram + rating-filter path
}
