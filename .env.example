# =============================================================
# Yobou — Environment variables
# Copy this file to `.env` (server) and fill in real values.
# The Vite client only reads keys prefixed with VITE_.
# =============================================================

# ---------- server ----------
NODE_ENV=development
PORT=4000

# SQLite for dev (no install required). Swap to a Postgres URL for production,
# e.g. postgres://user:pass@host:5432/yobou
DATABASE_URL="file:./dev.db"

# Long random strings — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=change-me-please-use-a-long-random-string-at-least-32-chars
JWT_REFRESH_SECRET=change-me-too-this-is-separate-from-the-access-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Frontend origin allowed by CORS (Vite default)
CORS_ORIGIN=http://localhost:5173

# Local file storage for product images
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=5

# Simulated payment realism — % of card attempts that fail
PAYMENT_DECLINE_RATE=0.05

# ---------- client (Vite — must start with VITE_) ----------
VITE_API_BASE=http://localhost:4000